# ─── OpEx Tower — Environment Configuration ───────────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.
#
#   cp .env.example .env.local

# ── Active AI Provider ────────────────────────────────────────────────────────
# Controls which AI backend powers the Nexus co-pilot.
# Options: gemini | claude | resilience
AI_PROVIDER=gemini

# ── Backend Server Port ───────────────────────────────────────────────────────
# The Express server runs on this port. Vite proxies /api/* to it automatically.
PORT=3001

# ── Gemini (Google AI Studio) ─────────────────────────────────────────────────
# Required when AI_PROVIDER=gemini
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Claude (Anthropic) ───────────────────────────────────────────────────────
# Required when AI_PROVIDER=claude
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Resilience Agent Network ─────────────────────────────────────────────────
# Required when AI_PROVIDER=resilience
# Point this at your running Resilience agent service
RESILIENCE_AGENT_URL=http://localhost:8080
RESILIENCE_AGENT_TOKEN=your_resilience_token_here_if_needed
